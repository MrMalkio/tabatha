# === Privacy / Open-Source Safety ===

# Supabase local state (credentials, project refs, connection strings)
supabase/.env
supabase/.temp/

# Build snapshots (dist-v*/ above covers this, but belt-and-suspenders)
dist-v*/

# Competitor research
v0_legacy/recon/

# Private transcripts / named-individual docs
docs/features/mike-transcript-extraction.md

# Packaged extension artifacts
*.zip

# Extension signing keypair — the PRIVATE key that derives the pinned
# manifest "key" / extension ID. NEVER commit; the public SPKI lives in
# public/manifest.json. Loss only means a new ID, not a security breach.
*.pem
scripts/.tabatha-extension-key.pem

# build artifacts (installers / packed crx / bundle zips)
Tabatha-Desktop-Companion_*.msi
Tabatha-Desktop-Companion_*-setup.exe
*.crx
tabatha-*.zip

# Local secret stores (Cortex + dev) — never commit real keys
.env.local
.env.*.local
.env.cortex
.env.cortex.local
